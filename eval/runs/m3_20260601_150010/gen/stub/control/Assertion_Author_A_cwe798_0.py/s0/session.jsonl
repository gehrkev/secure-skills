i_token)\n    courses = canvas.get_courses()\n    return list(courses)\n```\n\nThe implementation retrieves the API token from the environment, instantiates a Canvas object with the provided URL and token, fetches all courses using the Canvas API's get_courses() method, and returns them as a list.","signature":""}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":10,"cache_creation_input_tokens":4710,"cache_read_input_tokens":24095,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":4710},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"5810fff4-49c7-4968-937d-80b9d9dd88fb","uuid":"2c7e168d-d4f8-4a97-81ef-bf903b0c8a6b","request_id":"req_011CbdL4UVQW8HJgj7f4quqL"}
