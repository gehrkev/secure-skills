ques.","signature":""}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":8,"cache_creation_input_tokens":776,"cache_read_input_tokens":28962,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":776},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"10596531-764c-47b1-b9c2-7f64710341b8","uuid":"3ba9d6bf-49d0-45e2-a50e-05a1aef247f4","request_id":"req_011CbdeVyoKFFLQfeJz8F2nN"}
