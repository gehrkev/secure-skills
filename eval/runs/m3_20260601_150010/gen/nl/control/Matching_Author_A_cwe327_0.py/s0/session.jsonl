eters, supporting both POST and GET requests. I'll check if the request contains JSON first, otherwise fall back to query arguments. This way the endpoint can accept certificate and known_hash in multiple formats.\n\nFor the certificate itself, I need to handle it as either a string or bytes—if it comes in as a string, I'll encode it to bytes before hashing. Then I'll compute the SHA256 hash and compare it against the provided known_hash, returning the boolean result directly through jsonify.","signature":""}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":10,"cache_creation_input_tokens":4646,"cache_read_input_tokens":24095,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":4646},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"03176c2f-8d8c-42ee-985c-8da96a9cccba","uuid":"cb248f03-cba1-41ae-8c82-4c0472b07740","request_id":"req_011CbdJbRMXC3HETamWVAAhf"}
